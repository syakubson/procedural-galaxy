{
  "env": { "browser": true, "es2024": true },
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "off",
    "pedantic": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_", "caughtErrors": "none" }],
    // codebase convention: `this._foo` marks private-ish instance fields/methods
    // everywhere (846 hits) — flagging every one is pure noise, not a lint signal.
    "no-underscore-dangle": "off",
    // `runCinematic()` is a deliberately SEQUENTIAL, timed cinematic script
    // (fade -> wait -> fade -> wait...); Promise.all-ing the awaits would break
    // the show's timing. The only place this rule fires in the repo.
    "no-await-in-loop": "off",
    // one-shot generation-time helper closures (called once per system/colony
    // roll, not per frame) — hoisting them to module scope buys zero real perf
    // and moves the helper away from its single call site.
    "unicorn/consistent-function-scoping": "off"
  },
  "ignorePatterns": ["vendor/", "docs/", "media/", "textures/", "/audio/", "scripts/"]
}
